---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Juli y Lolo</title>
  </head>
  <body class="min-h-screen bg-linear-to-b from-[#0d1f2d] via-[#112a3a] to-[#0a1922]">
    <!-- Header -->
    <div class="max-w-2xl mx-auto px-4 pt-16 pb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-2" style="color: #40e0d0;">2 hermosos años</h1>
    </div>

    <!-- Carousel full-width -->
    <div class="relative w-full py-8">
      <div class="max-w-6xl mx-auto px-14 relative">
        <div id="carousel" class="relative w-full rounded-2xl overflow-hidden shadow-lg" style="background-color: #0f2533;">
          <div id="carouselTrack" class="relative w-full" style="aspect-ratio: 16/8;"></div>
          <div id="carouselDots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 z-10"></div>
        </div>

        <!-- Arrows outside -->
        <button id="carouselPrev" class="absolute left-0 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full flex items-center justify-center transition cursor-pointer z-10" style="background-color: rgba(13,31,45,0.8); color: #40e0d0; border: 1px solid rgba(64,224,208,0.3);">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        </button>
        <button id="carouselNext" class="absolute right-0 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full flex items-center justify-center transition cursor-pointer z-10" style="background-color: rgba(13,31,45,0.8); color: #40e0d0; border: 1px solid rgba(64,224,208,0.3);">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
        </button>
      </div>
    </div>

    <!-- Gallery -->
    <div class="max-w-5xl mx-auto px-4 pb-16">
      <div id="gallery" class="flex flex-col gap-12"></div>
    </div>

    <script>
      if (sessionStorage.getItem('autenticado') !== 'true') {
        window.location.href = '/';
      }

      const gallery = document.getElementById('gallery') as HTMLElement;

      // Carousel
      const carouselTrack = document.getElementById('carouselTrack') as HTMLElement;
      const carouselDots = document.getElementById('carouselDots') as HTMLElement;
      const carouselPrev = document.getElementById('carouselPrev') as HTMLElement;
      const carouselNext = document.getElementById('carouselNext') as HTMLElement;
      let currentSlide = 0;
      let carouselImages: HTMLImageElement[] = [];
      let autoplayInterval: ReturnType<typeof setInterval>;

      function buildCarousel(slides: { src: string; alt: string }[]) {
        slides.forEach((slide, i) => {
          const img = document.createElement('img');
          img.src = slide.src;
          img.alt = slide.alt;
          img.className = 'absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ease-in-out';
          img.style.opacity = i === 0 ? '1' : '0';
          carouselTrack.appendChild(img);
          carouselImages.push(img);

          const dot = document.createElement('button');
          dot.className = 'w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer';
          dot.style.backgroundColor = i === 0 ? '#40e0d0' : 'rgba(64,224,208,0.3)';
          dot.addEventListener('click', () => goToSlide(i));
          carouselDots.appendChild(dot);
        });
      }

      function goToSlide(index: number) {
        carouselImages[currentSlide].style.opacity = '0';
        (carouselDots.children[currentSlide] as HTMLElement).style.backgroundColor = 'rgba(64,224,208,0.3)';

        currentSlide = index;

        carouselImages[currentSlide].style.opacity = '1';
        (carouselDots.children[currentSlide] as HTMLElement).style.backgroundColor = '#40e0d0';

        resetAutoplay();
      }

      function nextSlide() {
        goToSlide((currentSlide + 1) % carouselImages.length);
      }

      function prevSlide() {
        goToSlide((currentSlide - 1 + carouselImages.length) % carouselImages.length);
      }

      function resetAutoplay() {
        clearInterval(autoplayInterval);
        autoplayInterval = setInterval(nextSlide, 4000);
      }

      carouselNext.addEventListener('click', nextSlide);
      carouselPrev.addEventListener('click', prevSlide);

      fetch('/data/carousel.json')
        .then((r) => r.json())
        .then((slides) => {
          buildCarousel(slides);
          resetAutoplay();
        });

      let mediaIndex = 0;

      async function loadGallery() {
        const res = await fetch('/data/gallery.json');
        const items = await res.json();

        items.forEach((item: { type: string; src?: string; alt?: string; text?: string; fecha?: string; modalTitle?: string; modalText?: string }) => {
          if (item.type === 'title') {
            const subtitle = document.createElement('h2');
            subtitle.className = 'fade-in opacity-0 translate-y-6 transition-all duration-700 text-center text-xl md:text-2xl font-semibold mt-4 mb-2';
            subtitle.style.color = '#f0b757';
            subtitle.textContent = item.text || '';
            gallery.appendChild(subtitle);

            const line = document.createElement('div');
            line.className = 'fade-in opacity-0 transition-all duration-700 mx-auto w-16 h-0.5 rounded-full mb-4';
            line.style.backgroundColor = '#40e0d0';
            gallery.appendChild(line);
            mediaIndex = 0;
            return;
          }

          const isLeft = mediaIndex % 2 === 0;
          mediaIndex++;

          const row = document.createElement('div');
          row.className = `fade-in opacity-0 translate-y-6 transition-all duration-700 flex flex-col ${isLeft ? 'md:flex-row' : 'md:flex-row-reverse'} gap-6 items-center`;

          const mediaContainer = document.createElement('div');
          mediaContainer.className = 'w-full md:w-1/2 rounded-2xl overflow-hidden group relative';
          mediaContainer.style.backgroundColor = '#0f2533';

          if (item.type === 'video') {
            const video = document.createElement('video');
            video.src = item.src;
            video.controls = true;
            video.className = 'w-full rounded-2xl transition-transform duration-500 group-hover:scale-[1.03]';
            video.muted = true;
            video.loop = true;
            mediaContainer.appendChild(video);
          } else {
            const img = document.createElement('img');
            img.src = item.src;
            img.alt = item.alt || '';
            img.loading = 'lazy';
            img.className = 'w-full rounded-2xl transition-transform duration-500 group-hover:scale-[1.03]';
            mediaContainer.appendChild(img);
          }

          const border = document.createElement('div');
          border.className = 'absolute inset-0 rounded-2xl border-2 border-transparent group-hover:border-[#40e0d0]/40 transition-colors duration-500 pointer-events-none';
          mediaContainer.appendChild(border);

          const textPanel = document.createElement('div');
          textPanel.className = 'w-full md:w-1/2 flex flex-col justify-center px-2';

          const title = document.createElement('h3');
          title.className = 'text-xl md:text-2xl font-bold mb-1';
          title.style.color = '#40e0d0';
          title.textContent = item.modalTitle || '';
          textPanel.appendChild(title);

          if (item.fecha) {
            const fecha = document.createElement('span');
            fecha.className = 'text-sm mb-3 block';
            fecha.style.color = '#f0b757';
            fecha.textContent = item.fecha;
            textPanel.appendChild(fecha);
          }

          const text = document.createElement('p');
          text.className = 'text-[#b0d4d1] leading-relaxed text-base';
          text.textContent = item.modalText || '';
          textPanel.appendChild(text);

          row.appendChild(mediaContainer);
          row.appendChild(textPanel);
          gallery.appendChild(row);
        });

        observeItems();
      }

      function observeItems() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.remove('opacity-0', 'translate-y-6');
                entry.target.classList.add('opacity-100', 'translate-y-0');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );

        document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
      }

      loadGallery();
    </script>
  </body>
</html>
